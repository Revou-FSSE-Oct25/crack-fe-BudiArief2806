{
  "info": {
    "_postman_id": "4f26f7f0-cd40-4897-9838-98c0510f9011",
    "name": "Diabstrok API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "bookingId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"User Postman\",\n  \"email\": \"postman@diabstrok.id\",\n  \"password\": \"user1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.accessToken) {",
                  "  pm.collectionVariables.set('token', data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@diabstrok.id\",\n  \"password\": \"admin1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.accessToken) {",
                  "  pm.collectionVariables.set('token', data.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rina@diabstrok.id\",\n  \"password\": \"user1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Master Data",
      "item": [
        {
          "name": "List Hospitals",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/hospitals"
          }
        },
        {
          "name": "List Doctors",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/doctors"
          }
        },
        {
          "name": "List Rooms",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/rooms"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.item && data.item.id) {",
                  "  pm.collectionVariables.set('bookingId', data.item.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hospitalId\": \"thb\",\n  \"doctorId\": \"d2\",\n  \"roomId\": \"r1\",\n  \"complaint\": \"Kontrol rutin diabetes\"\n}"
            },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "My Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/bookings/me"
          }
        },
        {
          "name": "Get Booking By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Update Booking Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            },
            "url": "{{baseUrl}}/bookings/{{bookingId}}/status"
          }
        },
        {
          "name": "Delete Booking",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/bookings/{{bookingId}}"
          }
        }
      ]
    },
    {
      "name": "Admin Bookings",
      "item": [
        {
          "name": "List All Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Create Prescription",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stage\": \"STADIUM_1\",\n  \"items\": [\n    \"Metformin 500mg 2x sehari setelah makan\"\n  ],\n  \"notes\": \"Kontrol 1 minggu\"\n}"
            },
            "url": "{{baseUrl}}/bookings/{{bookingId}}/prescription"
          }
        }
      ]
    }
  ]
}
